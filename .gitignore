# Go build artifacts
/bin/
*.exe
*.out
*.test
*.prof
coverage.html

# Go workspace: go.work IS committed (it defines the monorepo module layout),
# but go.work.sum is a local dependency-resolution cache, not a source artifact.
go.work.sum

# Local compose overrides (docker-compose.yml itself is committed)
deploy/compose/docker-compose.override.yml

# Local binaries built from cmd/
**/cmd/*/gateway
**/cmd/*/simulator
**/cmd/*/*-service

# Env / secrets (never commit real secrets)
.env
.env.local
*.local.env

# Node / frontend (Phase 3)
web/node_modules/
web/dist/
web/.vite/

# Editor / OS noise
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
